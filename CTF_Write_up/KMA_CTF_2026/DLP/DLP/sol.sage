59730779906163158939342189514934125806883758280286996788504562257993865363613319347145823536160959464466465806465587, 5398613906209023048909732737159613648852479966453836849788879952728730172518701198486253199045002850867160363230250937558653182044183960326675688151765497, 6927093282968141834576250480716041214939102483575449723439641884657117322493387549907560787217518989866790376247456841361532993015588710085685422414593618, 16400621666268991346010767065049264225544983053413059947879933909117127575349471564194609735567028221133177906791966543281861774951689328095794994551249351, 3454520373523786375962385541809338190890392291512123496466860086538451355524386818246670221724576344160392691425024940435058880818776510600254804348041372, 1776177272956846392835639093233790501584867047297907084518189953497891494516891993509150067412833101585024353934904840907756957463666445576650373187115892, 2800935387476605526957189119450497849627160369811622095664272611817408503974294682649291019339097019257801108064130275334983049658981560990745281243030742, 3167979305758865715882492633259555898044143880595684103490256002581883015715913510178367354662388111835418985217805103379520254161550833742603300918211453, 14473768408364157991811503900533946324395128385530505845058217756659467439416396282514123411418081135725364633257794232428268772449642862276895930585959043, 16577745989849229257740769954752811881344667671190867161502146168651581272000629767787578892766952834897092461511118694719853040171835251871183426118716932, 1888799299721201875886780773317666762119166326510454699623507757849669823256145998659703063252981892087545446843935389326238836321207338518665882894200572, 16485615252254289661762123362532059778654741895017558000938697277937485799963410273405372269219327244331884624031085497066411853313954524795340862834583757, 370162988001606432332779460272136340733113822483800459045552058228837824652942060694010601610465932592715657962511489632935454334707540776065509772126229, 17779109513188263846160921046412734713114130684983622149999589996823881647393660323361331738896250360359680695552014393971009585922116627536035660147984911, 5384932970725276830823107946541833097546404077548612277989846950244070496892999424133990712546627900538609983025627323177798935900014971401944273962277253, 7349703377985150490811642858053112453323654443861976790028815547412631813059741555129169240367007659037583175529025264594049102830687760250990206341950810, 12237363638563717391390602297511266711837032849316678266136572911080026628864971436628735646707468724932049297383798948241792521431863341403230334063443602, 12742074651393330541675236707568610718535407874812741589343595791290357231715986226703646014178946089955663506677208810370624644596195850995191854527839606]
N = 184
LAMBDA = 512

ell = max(xi.bit_length() for xi in x)

print(ell)
F = PolynomialRing(ZZ, 'm', ell)
ms = list(F.gens())

def xor(t1, t2):
    l1 = list(int(i) for i in format(t1, f'0{ell}b'))[::-1]
    tmp = 0
    for i, (x1, x2) in enumerate(zip(l1, t2[::-1])):
        tmp += (1 << i) * (x1 + (1 - 2*x1) * x2)
    return (tmp)

fs = [xor(t1, ms) for t1 in x]

rows = []
consts = []

for i, (f) in enumerate(fs):


    row = [f.monomial_coefficient(g) for g in ms]
    const = f.constant_coefficient()

    rows.append(row + [const])
    consts.append(const)

w = [1] * (ell + 1) + [1 << 128] * (N)

w = diagonal_matrix(w, sparse=0)
M = matrix(ZZ, rows)

M = block_matrix([
    [M, 1]
])

M /= w
M = M.LLL()
M *= w

a = []
for i in M:
    
    i = (i).list()
    if all(x == 0 for x in i[:ell + 1]):
        a.append(i[ell + 1:])

g = 0
for ai in a:

    v_2_1 = 1
    v_2_2 = 1

    for _, yi in zip(ai, y):
        if _ < 0:
            v_2_1 *= yi ** (-_)
        else:
            v_2_2 *= yi ** _

    k = abs(v_2_2 - v_2_1)
    g = k if g == 0 else gcd(g, k)

p = int(factor(g)[-1][0])
q = int((p - 1) // 2)

assert is_prime(p) and is_prime(q)

flag = ""
for i in trange(ell):
    w = [1] * (ell + 1) + [1 << 512] * (N)
    w[i] = 1 << (512)
    w = diagonal_matrix(w, sparse=0)
    M = matrix(ZZ, rows)

    M = block_matrix([
        [M, 1]
    ])
    M /= w
    M = M.LLL()
    M *= w

    v_2_2 = 1
    for _ in M:
        if _[i] != 0 and len(set(_[:ell + 1])) == 2:
            tmp = _
            break
    ai = tmp[ell + 1:]
    for _, yi in zip(ai, y):
        v_2_2 *= pow(yi, _, p)

    k = v_2_2 % p
    flag += "0" if k == 1 else "1"
    print(flag)
print(flag)
